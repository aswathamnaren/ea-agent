# ---------------------------------------------------------------------
# MCP mode
# ---------------------------------------------------------------------
MCP_USE_REAL_CLIENTS=false

# ---------------------------------------------------------------------
# Atlassian MCP - Jira + Confluence
# Local stdio MCP server using mcp-atlassian
# ---------------------------------------------------------------------
MCP_ATLASSIAN_TRANSPORT=stdio
MCP_ATLASSIAN_COMMAND=mcp-atlassian
MCP_ATLASSIAN_ARGS=--no-confluence-ssl-verify,--no-jira-ssl-verify,--transport,stdio

CONFLUENCE_URL=https://confluence.telefonica.de
CONFLUENCE_PERSONAL_TOKEN=
CONFLUENCE_SSL_VERIFY=false

JIRA_URL=https://jira.telefonica.de
JIRA_PERSONAL_TOKEN=
JIRA_SSL_VERIFY=false

TOOLSETS=all

# ---------------------------------------------------------------------
# ARCO MiniBot MCP - Enterprise RAG
# ---------------------------------------------------------------------
MCP_ARCO_TRANSPORT=http
MCP_ARCO_URL=https://chat.daai.ddc.telefonica.de/mcp/

# ---------------------------------------------------------------------
# MCP tool names
# These may need adjustment after tool discovery.
# ---------------------------------------------------------------------
MCP_JIRA_GET_ISSUE_TOOL=jira_get_issue
MCP_JIRA_SEARCH_TOOL=jira_search

MCP_CONFLUENCE_SEARCH_TOOL=confluence_search
MCP_CONFLUENCE_GET_PAGE_TOOL=confluence_get_page
MCP_CONFLUENCE_GET_CHILDREN_TOOL=confluence_get_page_children

MCP_ARCO_SEARCH_TOOL=search

# ---------------------------------------------------------------------
# Confluence knowledge parent pages
# Add page IDs or URLs separated by comma.
# Example:
# CONFLUENCE_PARENT_PAGE_URLS=https://confluence.telefonica.de/pages/viewpage.action?pageId=123,https://...
# ---------------------------------------------------------------------
CONFLUENCE_PARENT_PAGE_URLS=
CONFLUENCE_SPACES=ARCH,IAM,NMD,OpsVoice